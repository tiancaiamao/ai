func TestBooleanType(t *testing.T) {
	env := setupTestEnv()

	trueExpr, err := evalString("#t", env)
	if err != nil {
		t.Fatalf("evalString(#t) error = %v", err)
	}
	trueBool, ok := trueExpr.(Boolean)
	if !ok || trueBool.Value != true {
		t.Errorf("evalString(#t) = %v, want #t", trueExpr)
	}

	falseExpr, err := evalString("#f", env)
	if err != nil {
		t.Fatalf("evalString(#f) error = %v", err)
	}
	falseBool, ok := falseExpr.(Boolean)
	if !ok || falseBool.Value != false {
		t.Errorf("evalString(#f) = %v, want #f", falseExpr)
	}
}

func TestBooleanString(t *testing.T) {
	tests := []struct {
		input    Boolean
		expected string
	}{
		{Boolean{Value: true}, "#t"},
		{Boolean{Value: false}, "#f"},
	}

	for _, tt := range tests {
		if got := tt.input.String(); got != tt.expected {
			t.Errorf("Boolean.String() = %q, want %q", got, tt.expected)
		}
	}
}

func TestBooleanEval(t *testing.T) {
	env := NewEnvironment()

	trueVal := Boolean{Value: true}
	result, err := trueVal.Eval(env)
	if err != nil {
		t.Fatalf("Boolean.Eval() error = %v", err)
	}

	resultBool, ok := result.(Boolean)
	if !ok || resultBool.Value != true {
		t.Errorf("Boolean.Eval() = %v, want #t", result)
	}
}

func TestComplexExpression(t *testing.T) {
	env := setupTestEnv()

	// Factorial using defn
	_, err := evalString("(defn factorial [n] (if (= n 0) 1 (* n (factorial (- n 1)))))", env)
	if err != nil {
		t.Fatalf("evalString(defn factorial ...) error = %v", err)
	}

	result, err := evalString("(factorial 5)", env)
	if err != nil {
		t.Fatalf("evalString(factorial 5) error = %v", err)
	}

	num, ok := result.(Integer)
	if !ok || num.Value != 120 {
		t.Errorf("evalString(factorial 5) = %v, want 120", result)
	}
}

