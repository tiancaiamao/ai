package lisp

import (
	"testing"
)

func setupTestEnv() *Environment {
	InitEvaluator()
	return GlobalEnv()
}

// Helper function to parse and evaluate a string
func evalString(input string, env *Environment) (Expr, error) {
	lexer := NewLexer(input)
	tokens, err := lexer.Lex()
	if err != nil {
		return nil, err
	}

	parser := NewParser(tokens)
	exprs, err := parser.Parse()
	if err != nil {
		return nil, err
	}

	var result Expr
	for _, expr := range exprs {
		result, err = expr.Eval(env)
		if err != nil {
			return nil, err
		}
	}
	return result, nil
}

func TestBuiltinPlus(t *testing.T) {
	env := setupTestEnv()

	tests := []struct {
		input    string
		expected int64
	}{
		{"(+)", 0},
		{"(+ 1)", 1},
		{"(+ 1 2)", 3},
		{"(+ 1 2 3 4 5)", 15},
		{"(+ -1 1)", 0},
		{"(+ -5 -10)", -15},
	}

	for _, tt := range tests {
		t.Run(tt.input, func(t *testing.T) {
			result, err := evalString(tt.input, env)
			if err != nil {
				t.Fatalf("evalString(%q) error = %v", tt.input, err)
			}

			num, ok := result.(Integer)
			if !ok {
				t.Fatalf("evalString(%q) result type = %T, want Integer", tt.input, result)
			}

			if num.Value != tt.expected {
				t.Errorf("evalString(%q) = %d, want %d", tt.input, num.Value, tt.expected)
			}
		})
	}
}

func TestBuiltinPlusTypeError(t *testing.T) {
	env := setupTestEnv()

	_, err := evalString(`(+ 1 "hello")`, env)
	if err == nil {
		t.Error("evalString(+ 1 \"hello\") expected error, got nil")
	}
}

