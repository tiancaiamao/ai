func TestNestedLets(t *testing.T) {
	env := setupTestEnv()

	result, err := evalString("(let [x 1] (let [x (+ x 1)] x))", env)
	if err != nil {
		t.Fatalf("evalString(nested lets) error = %v", err)
	}

	num, ok := result.(Integer)
	if !ok || num.Value != 2 {
		t.Errorf("evalString(nested lets) = %v, want 2", result)
	}
}

func TestArgumentMismatch(t *testing.T) {
	env := setupTestEnv()

	_, err := evalString("(defn two-args [x y] (+ x y))", env)
	if err != nil {
		t.Fatalf("evalString(defn two-args [x y] (+ x y)) error = %v", err)
	}

	// Call with wrong number of arguments
	_, err = evalString("(two-args 1)", env)
	if err == nil {
		t.Error("evalString(two-args 1) expected error, got nil")
	}

	_, err = evalString("(two-args 1 2 3)", env)
	if err == nil {
		t.Error("evalString(two-args 1 2 3) expected error, got nil")
	}
}