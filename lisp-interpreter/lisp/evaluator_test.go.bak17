func TestBuiltinComparisons(t *testing.T) {
	env := setupTestEnv()

	tests := []struct {
		input    string
		expected bool
	}{
		{"(> 5 3)", true},
		{"(> 3 5)", false},
		{"(> 5 5)", false},
		{"(< 3 5)", true},
		{"(< 5 3)", false},
		{"(< 5 5)", false},
		{"(>= 5 3)", true},
		{"(>= 5 5)", true},
		{"(>= 3 5)", false},
		{"(<= 3 5)", true},
		{"(<= 5 5)", true},
		{"(<= 5 3)", false},
		{"(= 5 5)", true},
		{"(= 3 5)", false},
		{"(> 5 3 2 1)", true},
		{"(= 5 5 5)", true},
		{"= 5 5 6", false},
	}

	for _, tt := range tests {
		t.Run(tt.input, func(t *testing.T) {
			result, err := evalString(tt.input, env)
			if err != nil {
				t.Fatalf("evalString(%q) error = %v", tt.input, err)
			}

			b, ok := result.(Boolean)
			if !ok {
				t.Fatalf("evalString(%q) result type = %T, want Boolean", tt.input, result)
			}

			if b.Value != tt.expected {
				t.Errorf("evalString(%q) = %v, want %v", tt.input, b.Value, tt.expected)
			}
		})
	}
}

