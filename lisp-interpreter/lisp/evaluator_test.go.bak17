func TestSpecialLet(t *testing.T) {
	env := setupTestEnv()

	result, err := evalString("(let [x 10 y 20] (+ x y))", env)
	if err != nil {
		t.Fatalf("evalString(let [x 10 y 20] (+ x y)) error = %v", err)
	}

	num, ok := result.(Integer)
	if !ok || num.Value != 30 {
		t.Errorf("evalString(let [x 10 y 20] (+ x y)) = %v, want 30", result)
	}
}

func TestSpecialLetScoped(t *testing.T) {
	env := setupTestEnv()

	_, err := evalString("(def x 5)", env)
	if err != nil {
		t.Fatalf("evalString(def x 5) error = %v", err)
	}

	_, err = evalString("(let [x 10] x)", env)
	if err != nil {
		t.Fatalf("evalString(let [x 10] x) error = %v", err)
	}

	// Check that x is still 5 outside the let
	result, err := evalString("x", env)
	if err != nil {
		t.Fatalf("evalString(x) error = %v", err)
	}

	num, ok := result.(Integer)
	if !ok || num.Value != 5 {
		t.Errorf("evalString(x) = %v, want 5 (let should not affect outer scope)", result)
	}
}

