func TestSpecialDef(t *testing.T) {
	env := setupTestEnv()

	_, err := evalString("(def x 42)", env)
	if err != nil {
		t.Fatalf("evalString(def x 42) error = %v", err)
	}

	result, err := evalString("x", env)
	if err != nil {
		t.Fatalf("evalString(x) error = %v", err)
	}

	num, ok := result.(Integer)
	if !ok || num.Value != 42 {
		t.Errorf("evalString(x) = %v, want 42", result)
	}
}

