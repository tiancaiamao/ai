func TestSpecialQuote(t *testing.T) {
	env := setupTestEnv()

	result, err := evalString("(quote (+ 1 2))", env)
	if err != nil {
		t.Fatalf("evalString(quote (+ 1 2)) error = %v", err)
	}

	list, ok := result.(List)
	if !ok {
		t.Fatalf("evalString(quote (+ 1 2)) result type = %T, want List", result)
	}

	if len(list.Items) != 3 {
		t.Errorf("evalString(quote (+ 1 2)) list.Items length = %d, want 3", len(list.Items))
	}

	sym, ok := list.Items[0].(Symbol)
	if !ok || sym.Name != "+" {
		t.Errorf("evalString(quote (+ 1 2)) first item = %v, want +", list.Items[0])
	}
}

func TestSpecialQuoteShortSyntax(t *testing.T) {
	env := setupTestEnv()

	result, err := evalString("'(+ 1 2)", env)
	if err != nil {
		t.Fatalf("evalString('(+ 1 2)) error = %v", err)
	}

	list, ok := result.(List)
	if !ok {
		t.Fatalf("evalString('(+ 1 2)) result type = %T, want List", result)
	}

	// Quote syntax 'x is transformed to (quote x)
	// So we should get a list with "quote" as first element and the quoted list as second
	sym, ok := list.Items[0].(Symbol)
	if !ok || sym.Name != "quote" {
		t.Errorf("evalString('(+ 1 2)) first item = %v, want quote", list.Items[0])
	}

	quotedList, ok := list.Items[1].(List)
	if !ok || len(quotedList.Items) != 3 {
		t.Errorf("evalString('(+ 1 2)) second item = %v, want list with 3 items", list.Items[1])
	}
}

