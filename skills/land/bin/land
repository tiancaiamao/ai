#!/bin/bash
# Land Skill - Merge PR with safety checks
# Usage: land <pr-url-or-number> [task-id]

set -e

PR_REF="${1:-}"
TASK_ID="${2:-}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Helper functions
log_info() {
    echo -e "${BLUE}ℹ️  $1${NC}"
}

log_success() {
    echo -e "${GREEN}✅ $1${NC}"
}

log_error() {
    echo -e "${RED}❌ $1${NC}"
}

log_warn() {
    echo -e "${YELLOW}⚠️  $1${NC}"
}

# Check prerequisites
check_prerequisites() {
    if ! command -v gh &> /dev/null; then
        log_error "GitHub CLI (gh) not found"
        echo "Install from: https://cli.github.com/"
        exit 1
    fi

    if ! gh auth status &> /dev/null; then
        log_error "GitHub CLI not authenticated"
        echo "Run: gh auth login"
        exit 1
    fi
}

# Get PR info
get_pr_info() {
    gh pr view "$PR_REF" --json \
        reviewDecision,\
        state,\
        mergeable,\
        statusCheckRollup,\
        url,\
        title
}

# Main land function
land() {
    if [ -z "$PR_REF" ]; then
        # Try to detect PR from current branch
        PR_REF=$(gh pr view --json number -q .number 2>/dev/null || echo "")
        if [ -z "$PR_REF" ]; then
            log_error "No PR found for current branch"
            echo "Usage: land <pr-url-or-number> [task-id]"
            exit 1
        fi
        log_info "Using PR #$PR_REF from current branch"
    fi

    log_info "🚀 Starting land process for PR: $PR_REF"

    # 1. Get PR status
    log_info "📋 Checking PR status..."
    PR_INFO=$(get_pr_info)

    REVIEW_DECISION=$(echo "$PR_INFO" | jq -r .reviewDecision)
    STATE=$(echo "$PR_INFO" | jq -r .state)
    MERGEABLE=$(echo "$PR_INFO" | jq -r .mergeable)
    PR_URL=$(echo "$PR_INFO" | jq -r .url)
    PR_TITLE=$(echo "$PR_INFO" | jq -r .title)

    echo "  Review: $REVIEW_DECISION"
    echo "  State: $STATE"
    echo "  Mergeable: $MERGEABLE"
    echo "  URL: $PR_URL"
    echo "  Title: $PR_TITLE"

    # 2. Validate state
    if [ "$STATE" != "OPEN" ]; then
        log_error "PR is not open (state: $STATE)"
        exit 1
    fi

    # 3. Check approval
    if [ "$REVIEW_DECISION" != "APPROVED" ]; then
        log_error "PR not approved (review: $REVIEW_DECISION)"

        if [ -n "$TASK_ID" ]; then
            log_warn "Moving task back to Human Review"
            curl -s -X PUT "http://localhost:8080/api/tasks/$TASK_ID" \
                -H "Content-Type: application/json" \
                -d '{"state": "todo"}' > /dev/null
        fi

        gh pr comment "$PR_REF" --body "⏸️ **Land blocked**: PR requires approval before merge."
        exit 1
    fi

    # 4. Handle merge conflicts
    if [ "$MERGEABLE" == "CONFLICTING" ]; then
        log_warn "Merge conflicts detected"

        # Try to rebase
        log_info "Attempting to rebase onto main..."
        git fetch origin main

        if git rebase origin/main; then
            log_success "Rebase successful"
            git push --force-with-lease
            log_success "Force pushed rebased branch"

            # Wait a moment for GitHub to process
            sleep 3

            # Re-check mergeable status
            PR_INFO=$(get_pr_info)
            MERGEABLE=$(echo "$PR_INFO" | jq -r .mergeable)

            if [ "$MERGEABLE" == "CONFLICTING" ]; then
                log_error "Still conflicting after rebase"
                gh pr comment "$PR_REF" --body "⚠️ **Merge conflicts**: Could not resolve automatically. Manual intervention required."

                if [ -n "$TASK_ID" ]; then
                    curl -s -X PUT "http://localhost:8080/api/tasks/$TASK_ID" \
                        -H "Content-Type: application/json" \
                        -d '{"state": "running"}' > /dev/null
                fi

                exit 1
            fi
        else
            log_error "Could not rebase automatically"
            git rebase --abort 2>/dev/null || true

            gh pr comment "$PR_REF" --body "⚠️ **Merge conflicts**: Could not rebase automatically. Manual resolution required."

            if [ -n "$TASK_ID" ]; then
                curl -s -X PUT "http://localhost:8080/api/tasks/$TASK_ID" \
                    -H "Content-Type: application/json" \
                    -d '{"state": "running"}' > /dev/null
            fi

            exit 1
        fi
    fi

    # 5. Wait for checks
    log_info "🔍 Checking CI status..."

    CHECKS_FAILED=0
    MAX_WAIT=60  # 10 minutes
    WAIT_COUNT=0

    while [ $WAIT_COUNT -lt $MAX_WAIT ]; do
        PR_INFO=$(get_pr_info)
        CHECKS=$(echo "$PR_INFO" | jq -r '.statusCheckRollup // []')

        FAILURES=$(echo "$CHECKS" | jq '[.[] | select(.conclusion == "FAILURE")] | length')
        PENDING=$(echo "$CHECKS" | jq '[.[] | select(.status == "IN_PROGRESS" or .status == "QUEUED")] | length')
        SUCCESS=$(echo "$CHECKS" | jq '[.[] | select(.conclusion == "SUCCESS")] | length')

        if [ "$FAILURES" -gt 0 ]; then
            log_error "CI checks failed ($FAILURES failures)"

            FAILED_CHECKS=$(echo "$CHECKS" | jq -r '.[] | select(.conclusion == "FAILURE") | .name' | tr '\n' ' ')
            log_error "Failed checks: $FAILED_CHECKS"

            gh pr comment "$PR_REF" --body "❌ **Land blocked**: CI checks failed.\n\nFailed checks: $FAILED_CHECKS"

            if [ -n "$TASK_ID" ]; then
                curl -s -X PUT "http://localhost:8080/api/tasks/$TASK_ID" \
                    -H "Content-Type: application/json" \
                    -d '{"state": "running"}' > /dev/null
            fi

            exit 1
        fi

        if [ "$PENDING" -eq 0 ]; then
            log_success "All CI checks passed ($SUCCESS checks)"
            break
        fi

        log_info "Waiting for checks... ($PENDING pending, $SUCCESS passed)"
        sleep 10
        WAIT_COUNT=$((WAIT_COUNT + 1))
    done

    if [ $WAIT_COUNT -ge $MAX_WAIT ]; then
        log_warn "Timed out waiting for checks, proceeding anyway..."
    fi

    # 6. Merge the PR
    log_info "🔀 Merging PR..."

    if gh pr merge "$PR_REF" --squash --delete-branch --subject "$PR_TITLE"; then
        log_success "PR merged successfully!"
    else
        log_error "Failed to merge PR"
        exit 1
    fi

    # 7. Update task state
    if [ -n "$TASK_ID" ]; then
        log_info "Updating task state to done..."
        curl -s -X PUT "http://localhost:8080/api/tasks/$TASK_ID" \
            -H "Content-Type: application/json" \
            -d '{"state": "done"}' > /dev/null
        log_success "Task marked as done"
    fi

    # 8. Send notification
    if [ -n "$SLACK_WEBHOOK" ]; then
        log_info "Sending Slack notification..."
        curl -s -X POST "$SLACK_WEBHOOK" \
            -H "Content-Type: application/json" \
            -d "{\"text\": \"✅ Merged: $PR_TITLE\nPR: $PR_URL\"}" > /dev/null
    fi

    # 9. Summary
    echo ""
    log_success "🎉 Land complete!"
    echo "  PR: $PR_URL"
    echo "  Title: $PR_TITLE"
    if [ -n "$TASK_ID" ]; then
        echo "  Task: $TASK_ID"
    fi
}

# Run
check_prerequisites
land "$@"