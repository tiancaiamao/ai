#!/bin/bash
# Symphony CLI - Interact with Symphony task orchestration

set -e

API_BASE="http://localhost:8081/api"
BOARD_URL="http://localhost:8081/board"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Helper: JSON pretty print
json_pp() {
    if command -v jq &> /dev/null; then
        jq .
    else
        python3 -m json.tool 2>/dev/null || cat
    fi
}

# Helper: Check if server is running
check_server() {
    if ! curl -s http://localhost:8081/health > /dev/null 2>&1; then
        echo -e "${RED}Error: Symphony server is not running${NC}"
        echo "Start it with: cd go && go run cmd/server/main.go"
        exit 1
    fi
}

# Task commands
task_create() {
    local title="$1"
    local description="${2:-}"

    if [ -z "$title" ]; then
        echo -e "${RED}Error: Task title required${NC}"
        echo "Usage: symphony task create <title> [--desc <description>]"
        exit 1
    fi

    check_server

    local json="{\"title\":\"$title\""
    if [ -n "$description" ]; then
        json="$json,\"description\":\"$description\""
    fi
    json="$json}"

    echo -e "${BLUE}Creating task...${NC}"
    curl -s -X POST "$API_BASE/tasks" \
        -H "Content-Type: application/json" \
        -d "$json" | json_pp
    echo
}

task_list() {
    local state="$1"

    check_server

    local url="$API_BASE/tasks"
    if [ -n "$state" ]; then
        url="$url?state=$state"
    fi

    curl -s "$url" | json_pp
}

task_show() {
    local id="$1"

    if [ -z "$id" ]; then
        echo -e "${RED}Error: Task ID required${NC}"
        echo "Usage: symphony task show <id>"
        exit 1
    fi

    check_server
    curl -s "$API_BASE/tasks/$id" | json_pp
}

task_move() {
    local id="$1"
    local state="$2"

    if [ -z "$id" ] || [ -z "$state" ]; then
        echo -e "${RED}Error: Task ID and state required${NC}"
        echo "Usage: symphony task move <id> <state>"
        echo "States: inbox, todo, running, done, failed"
        exit 1
    fi

    check_server

    echo -e "${BLUE}Moving task $id to $state...${NC}"
    curl -s -X PUT "$API_BASE/tasks/$id" \
        -H "Content-Type: application/json" \
        -d "{\"state\":\"$state\"}" | json_pp
    echo
}

task_retry() {
    local id="$1"

    if [ -z "$id" ]; then
        echo -e "${RED}Error: Task ID required${NC}"
        echo "Usage: symphony task retry <id>"
        exit 1
    fi

    check_server

    echo -e "${BLUE}Retrying task $id...${NC}"
    curl -s -X POST "$API_BASE/tasks/$id/retry" | json_pp
    echo
}

# Status command
show_status() {
    check_server
    echo -e "${BLUE}Scheduler Status:${NC}"
    curl -s "$API_BASE/status" | json_pp
}

# Board command
open_board() {
    echo -e "${BLUE}Opening Kanban board: $BOARD_URL${NC}"
    if command -v open &> /dev/null; then
        open "$BOARD_URL"
    elif command -v xdg-open &> /dev/null; then
        xdg-open "$BOARD_URL"
    else
        echo "Open manually: $BOARD_URL"
    fi
}

# Help
show_help() {
    cat << 'EOF'
Symphony - Task Orchestration CLI

Commands:
  task create <title> [--desc <desc>]   Create a new task
  task list [state]                     List tasks (all or by state)
  task show <id>                        Show task details
  task move <id> <state>                Move task to new state
  task retry <id>                       Retry a failed task
  status                                Show scheduler status
  board                                 Open Kanban board in browser
  help                                  Show this help

States:
  inbox, todo, running, done, failed

Examples:
  symphony task create "Fix login bug"
  symphony task create "Add feature" --desc "Detailed description here"
  symphony task list
  symphony task list running
  symphony task move abc-123 todo
  symphony status
  symphony board

EOF
}

# Main CLI
main() {
    local command="${1:-help}"
    shift || true

    case "$command" in
        task)
            local subcommand="${1:-}"
            shift || true

            case "$subcommand" in
                create)
                    local title="$1"
                    shift || true
                    local desc=""

                    # Parse --desc flag
                    while [ $# -gt 0 ]; do
                        case "$1" in
                            --desc|-d)
                                desc="$2"
                                shift 2
                                ;;
                            *)
                                shift
                                ;;
                        esac
                    done

                    task_create "$title" "$desc"
                    ;;
                list)
                    task_list "$1"
                    ;;
                show)
                    task_show "$1"
                    ;;
                move)
                    task_move "$1" "$2"
                    ;;
                retry)
                    task_retry "$1"
                    ;;
                *)
                    echo -e "${RED}Unknown task command: $subcommand${NC}"
                    show_help
                    exit 1
                    ;;
            esac
            ;;
        status)
            show_status
            ;;
        board)
            open_board
            ;;
        help|--help|-h)
            show_help
            ;;
        *)
            echo -e "${RED}Unknown command: $command${NC}"
            show_help
            exit 1
            ;;
    esac
}

main "$@"